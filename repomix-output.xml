<!DOCTYPE html>
<html lang="ru" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title th:text="${product.id != null ? 'Редактировать товар' : 'Добавить товар'}">Форма товара</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-white">

<nav class="navbar navbar-expand-lg navbar-dark bg-black sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/admin">Админка ShlyapOff</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="/">На сайт</a></li>
                <li class="nav-item"><a class="nav-link" href="/logout">Выйти</a></li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-5">
    <h1 class="mb-4" th:text="${product.id != null ? 'Редактировать товар' : 'Добавить товар'}">Форма</h1>

    <form th:action="${product.id != null ? '/admin/product/edit/' + product.id : '/admin/product/create'}"
          method="post"
          enctype="multipart/form-data">

        <div class="mb-3">
            <label for="name" class="form-label">Название товара</label>
            <input type="text" class="form-control bg-dark text-white" id="name" name="name"
                   th:value="${product.name}" required>
        </div>

        <div class="mb-3">
            <label for="description" class="form-label">Описание</label>
            <textarea class="form-control bg-dark text-white" id="description" name="description" rows="3"
                      th:text="${product.description}" required></textarea>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="price" class="form-label">Цена (₽)</label>
                <input type="number" step="0.01" class="form-control bg-dark text-white" id="price" name="price"
                       th:value="${product.price}" required>
            </div>

            <div class="col-md-6 mb-3">
                <label for="category_id" class="form-label">Категория</label>
                <select class="form-select bg-dark text-white" id="category_id" name="category_id" required>
                    <option value="">Выберите категорию</option>
                    <option th:each="category : ${categories}"
                            th:value="${category.id}"
                            th:text="${category.name}"
                            th:selected="${product.category != null && product.category.id == category.id}">
                    </option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="brand_id" class="form-label">Бренд</label>
                <select class="form-select bg-dark text-white" id="brand_id" name="brand_id" required>
                    <option value="">Выберите бренд</option>
                    <option th:each="brand : ${brands}"
                            th:value="${brand.id}"
                            th:text="${brand.name}"
                            th:selected="${product.brand != null && product.brand.id == brand.id}">
                    </option>
                </select>
            </div>

            <div class="col-md-3 mb-3">
                <label for="nicotineStrength" class="form-label">Крепость никотина</label>
                <input type="text" class="form-control bg-dark text-white" id="nicotineStrength" name="nicotineStrength"
                       th:value="${product.nicotineStrength}" placeholder="Например: 20 мг/мл">
            </div>

            <div class="col-md-3 mb-3">
                <label for="volume" class="form-label">Объем</label>
                <input type="text" class="form-control bg-dark text-white" id="volume" name="volume"
                       th:value="${product.volume}" placeholder="Например: 10 мл">
            </div>
        </div>

        <div class="mb-3">
            <label for="imageFile" class="form-label">Изображение товара</label>
            <input type="file" class="form-control bg-dark text-white" id="imageFile" name="imageFile" accept="image/*">
            <div th:if="${product.imageUrl != null}" class="mt-2">
                <small class="text-white-50">Текущее изображение:</small>
                <img th:src="${product.imageUrl}" alt="Текущее изображение" class="img-thumbnail mt-2" style="max-width: 200px;">
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning" th:text="${product.id != null ? 'Сохранить изменения' : 'Добавить товар'}">Сохранить</button>
            <a href="/admin" class="btn btn-outline-light">Отмена</a>
        </div>
    </form>
</div>

</body>
</html>
</file>

<file path="src/main/resources/templates/admin/variants.html">
<!DOCTYPE html>
<html lang="ru" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Управление вкусами - ShlyapOff</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-white">

<nav class="navbar navbar-expand-lg navbar-dark bg-black sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/admin">Админка ShlyapOff</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="/admin">Товары</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/customers">Клиенты</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/loyalty">Лояльность</a></li>
                <li class="nav-item"><a class="nav-link" href="/">На сайт</a></li>
                <li class="nav-item">
                    <form th:action="@{/logout}" method="post" class="d-inline">
                        <button type="submit" class="nav-link btn btn-link text-white-50 text-decoration-none p-0 border-0">Выйти</button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-5">
    <div th:if="${successMessage}" class="alert alert-success alert-dismissible fade show">
        <span th:text="${successMessage}"></span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    <h1 class="mb-4">Управление вкусами: <span th:text="${product.name}">Товар</span></h1>

    <!-- Форма добавления вкуса -->
    <div class="card bg-black mb-4">
        <div class="card-body">
            <h5>Добавить новый вкус</h5>
            <form th:action="@{/admin/product/{id}/variant/add(id=${product.id})}" method="post" class="row g-3">
                <div class="col-md-6">
                    <input type="text" name="flavorName" class="form-control bg-dark text-white"
                           placeholder="Название вкуса (например: Вишнёвая кола)" required>
                </div>
                <div class="col-md-3">
                    <select name="inStock" class="form-select bg-dark text-white">
                        <option value="true">В наличии</option>
                        <option value="false">Нет в наличии</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-warning w-100">Добавить</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Список вкусов -->
    <div class="card bg-black">
        <div class="card-body">
            <h5>Существующие вкусы</h5>
            <div th:if="${#lists.isEmpty(variants)}" class="alert alert-info">
                Пока нет добавленных вкусов
            </div>
            <div th:if="${!#lists.isEmpty(variants)}" class="list-group">
                <div th:each="variant : ${variants}" class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center">
                    <div>
                        <span th:if="${variant.inStock}" class="text-success me-2">✓</span>
                        <span th:if="${!variant.inStock}" class="text-danger me-2">✗</span>
                        <span th:text="${variant.flavorName}">Вкус</span>
                        <span th:if="${!variant.inStock}" class="badge bg-secondary ms-2">Нет в наличии</span>
                    </div>
                    <div class="d-flex gap-2">
                        <form th:action="@{/admin/product/variant/{id}/toggle(id=${variant.id})}" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-light">
                                <span th:text="${variant.inStock} ? 'Скрыть' : 'Показать'">Переключить</span>
                            </button>
                        </form>
                        <form th:action="@{/admin/product/variant/{id}/delete(id=${variant.id})}" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Удалить этот вкус?')">Удалить</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a href="/admin" class="btn btn-outline-light">← Назад к товарам</a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
</file>

