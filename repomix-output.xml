        <tr th:each="order : ${orders}">
            <td th:text="${order.id}">1</td>
            <td th:text="${order.customerName}">Имя</td>
            <td th:text="${order.phone}">Телефон</td>
            <td th:text="${order.subtotalAmount} + ' ₽'">0 ₽</td>
            <td th:text="${order.discountPercent} + '%'">0%</td>
            <td th:text="${order.totalAmount} + ' ₽'">0 ₽</td>
            <td>
                <span th:switch="${order.status}">
                    <span th:case="'NEW'" class="badge bg-secondary">Новый</span>
                    <span th:case="'PROCESSING'" class="badge bg-warning text-dark">В обработке</span>
                    <span th:case="'COMPLETED'" class="badge bg-success">Выполнен</span>
                    <span th:case="'CANCELLED'" class="badge bg-danger">Отменён</span>
                    <span th:case="*" th:text="${order.status}" class="badge bg-secondary"></span>
                </span>
            </td>
            <td>
                <form th:action="@{/admin/orders/{id}/status(id=${order.id})}" method="post" class="d-flex gap-2">
                    <select name="status" class="form-select form-select-sm bg-dark text-white border-secondary">
                        <option value="NEW" th:selected="${order.status == 'NEW'}">Новый</option>
                        <option value="PROCESSING" th:selected="${order.status == 'PROCESSING'}">В обработке</option>
                        <option value="COMPLETED" th:selected="${order.status == 'COMPLETED'}">Выполнен</option>
                        <option value="CANCELLED" th:selected="${order.status == 'CANCELLED'}">Отменён</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-outline-light">Сохранить</button>
                </form>
            </td>
        </tr>
        <tr th:if="${orders.isEmpty()}">
            <td colspan="8" class="text-white-50">Заказов пока нет.</td>
        </tr>
        </tbody>
    </table>
</div>

</body>
</html>
